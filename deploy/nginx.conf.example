# Реверс-прокси nginx перед Next.js (порт 3000) для ukusi-nsk.ru
# Установка:
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/ukusi
#   sudo ln -s /etc/nginx/sites-available/ukusi /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d ukusi-nsk.ru -d www.ukusi-nsk.ru

server {
    listen 80;
    server_name ukusi-nsk.ru www.ukusi-nsk.ru;

    # Загрузки картинок — отдаём напрямую, без прокси на Node
    location /uploads/ {
        alias /root/site-/public/uploads/;
        expires 30d;
        access_log off;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    client_max_body_size 6M;
}

# certbot добавит сюда блок listen 443 ssl и редирект с 80 на 443 автоматически
