# Пример конфига nginx как реверс-прокси перед Next.js (порт 3000)
# Скопируйте в /etc/nginx/sites-available/furshet, замените YOUR_DOMAIN,
# затем: ln -s /etc/nginx/sites-available/furshet /etc/nginx/sites-enabled/
# и получите HTTPS-сертификат: sudo certbot --nginx -d YOUR_DOMAIN -d www.YOUR_DOMAIN

server {
    listen 80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # Загрузки картинок — отдаём напрямую, без прокси на Node
    location /uploads/ {
        alias /path/to/site/public/uploads/;
        expires 30d;
        access_log off;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    client_max_body_size 6M;
}

# certbot добавит сюда блок listen 443 ssl и редирект с 80 на 443 автоматически
